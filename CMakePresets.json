{
  "version": 3,
  "cmakeMinimumRequired": { "major": 3, "minor": 25, "patch": 0 },
  "configurePresets": [
    {
      "name": "headless",
      "displayName": "Linux headless EGL (mbgl-render -> PNG)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "CMAKE_C_COMPILER": "clang",
        "CMAKE_CXX_COMPILER": "clang++"
      }
    },
    {
      "name": "desktop",
      "displayName": "Linux desktop GLFW + Wayland window (mbgl-glfw)",
      "inherits": "headless",
      "binaryDir": "${sourceDir}/build-desktop",
      "cacheVariables": {
        "MLN_WITH_GLFW": "ON",
        "MLN_WITH_WAYLAND": "ON"
      }
    },
    {
      "name": "macos",
      "displayName": "macOS headless Metal (mbgl-render -> PNG)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build-macos",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "MLN_WITH_METAL": "ON",
        "CMAKE_OSX_DEPLOYMENT_TARGET": "14.3"
      },
      "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Darwin" }
    },
    {
      "name": "macos-desktop",
      "displayName": "macOS desktop GLFW + Metal window (mbgl-glfw)",
      "inherits": "macos",
      "binaryDir": "${sourceDir}/build-macos-desktop",
      "cacheVariables": {
        "MLN_WITH_GLFW": "ON"
      }
    }
  ],
  "buildPresets": [
    { "name": "headless", "configurePreset": "headless", "targets": ["mbgl-render"] },
    { "name": "desktop", "configurePreset": "desktop", "targets": ["mbgl-glfw"] },
    { "name": "macos", "configurePreset": "macos", "targets": ["mbgl-render"] },
    { "name": "macos-desktop", "configurePreset": "macos-desktop", "targets": ["mbgl-glfw"] }
  ]
}

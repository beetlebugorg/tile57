{
  "version": 3,
  "cmakeMinimumRequired": { "major": 3, "minor": 25, "patch": 0 },
  "configurePresets": [
    {
      "name": "headless",
      "displayName": "Linux headless EGL (chart -> PNG)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "CMAKE_C_COMPILER": "clang",
        "CMAKE_CXX_COMPILER": "clang++"
      }
    },
    {
      "name": "macos",
      "displayName": "macOS headless Metal (chart -> PNG)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build-macos",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "MLN_WITH_METAL": "ON",
        "CMAKE_OSX_DEPLOYMENT_TARGET": "14.3"
      },
      "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Darwin" }
    }
  ],
  "buildPresets": [
    { "name": "headless", "configurePreset": "headless", "targets": ["chartplotter-render"] },
    { "name": "macos", "configurePreset": "macos", "targets": ["chartplotter-render"] }
  ]
}
